{
  "info": {
    "name": "Relay Chat - v1.1.0 New Features",
    "description": "API endpoints for all newly implemented features in v1.1.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Message Search",
      "item": [
        {
          "name": "Search All Messages",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/messages/search?query=hello&limit=20&skip=0",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "messages", "search"],
              "query": [
                {
                  "key": "query",
                  "value": "hello",
                  "description": "Search query"
                },
                {
                  "key": "limit",
                  "value": "20",
                  "description": "Results per page"
                },
                {
                  "key": "skip",
                  "value": "0",
                  "description": "Skip N results"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Search in Conversation",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/messages/search?query=hello&conversationId={{CONVERSATION_ID}}&limit=20",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "messages", "search"],
              "query": [
                {
                  "key": "query",
                  "value": "hello"
                },
                {
                  "key": "conversationId",
                  "value": "{{CONVERSATION_ID}}"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Search by Sender",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/messages/search?query=hello&senderId={{USER_ID}}",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "messages", "search"],
              "query": [
                {
                  "key": "query",
                  "value": "hello"
                },
                {
                  "key": "senderId",
                  "value": "{{USER_ID}}"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Group Management",
      "item": [
        {
          "name": "Add Member to Group",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{USER_ID}}\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/conversations/{{GROUP_ID}}/members",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "conversations", "{{GROUP_ID}}", "members"]
            }
          },
          "response": []
        },
        {
          "name": "Remove Member from Group",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/conversations/{{GROUP_ID}}/members/{{USER_ID}}",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "conversations", "{{GROUP_ID}}", "members", "{{USER_ID}}"]
            }
          },
          "response": []
        },
        {
          "name": "Update Group Info",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Group Name\",\n  \"avatar\": \"https://example.com/avatar.jpg\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/conversations/{{GROUP_ID}}",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "conversations", "{{GROUP_ID}}"]
            }
          },
          "response": []
        },
        {
          "name": "Leave Group",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/conversations/{{GROUP_ID}}/leave",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "conversations", "{{GROUP_ID}}", "leave"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Mute & Archive",
      "item": [
        {
          "name": "Mute Conversation",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/conversations/{{CONVERSATION_ID}}/mute",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "conversations", "{{CONVERSATION_ID}}", "mute"]
            }
          },
          "response": []
        },
        {
          "name": "Unmute Conversation",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/conversations/{{CONVERSATION_ID}}/mute",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "conversations", "{{CONVERSATION_ID}}", "mute"]
            }
          },
          "response": []
        },
        {
          "name": "Archive Conversation",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/conversations/{{CONVERSATION_ID}}/archive",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "conversations", "{{CONVERSATION_ID}}", "archive"]
            }
          },
          "response": []
        },
        {
          "name": "Unarchive Conversation",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/conversations/{{CONVERSATION_ID}}/archive",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "conversations", "{{CONVERSATION_ID}}", "archive"]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost:4000",
      "type": "string"
    },
    {
      "key": "CONVERSATION_ID",
      "value": "",
      "type": "string"
    },
    {
      "key": "GROUP_ID",
      "value": "",
      "type": "string"
    },
    {
      "key": "USER_ID",
      "value": "",
      "type": "string"
    }
  ]
}
