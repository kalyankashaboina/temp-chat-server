{
  "name": "relay-chat-backend",
  "version": "1.0.0",
  "description": "Relay Chat - production backend by Kalyan Kashaboina",
  "main": "dist/server.js",
  "type": "commonjs",
  "license": "ISC",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "seed": "ts-node src/scripts/seed.ts",
    "ci:local": "sh scripts/backend-ci-check.sh"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@types/compression": "^1.8.1",
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "cloudinary": "^2.5.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.0",
    "google-auth-library": "^9.15.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "redis": "^5.11.0",
    "socket.io": "^4.8.3",
    "winston": "^3.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie": "^0.6.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.11.0",
    "@types/nodemailer": "^6.4.17",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "mongodb-memory-server": "^11.0.1",
    "prettier": "^3.8.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
